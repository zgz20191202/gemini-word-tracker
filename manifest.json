{
  "manifest_version": 3,
  "name": "Gemini Word Tracker",
  "version": "1.1.0",
  "description": "Tracks daily words inputted to and read from Gemini Web UI, comparing it to reading books.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://gemini.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://gemini.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ]
}
